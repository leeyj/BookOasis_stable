# --- BookOasis 설정 ---



# 메타데이터 설정 (예: 한국의 경우 aladin, 미국의 경우 google 등) - 현재는 한국의 알라딘만 지원
#METADATA_PROVIDER=aladin
#ALADIN=your_aladin_ttbkey_here

# 운영 시에는 아래 값 개개인에 맞게 설정 및 유지해야 합니다. | During operation, the values ​​below must be set and maintained according to each individual.
SECRET_KEY=yoursupersecretfixedkey12345!

# 🌟 뷰어 콘솔 로깅 제어 (디버그 모드 작동 시에만 true) |  🌟 Viewer console logging control (true only when debug mode is enabled)
VIEW_LOG=false

# 🌟 외부 연동 웹훅 전역 보안 API 토큰 | 🌟 Global security API token for external integration webhooks
WEBHOOK_TOKEN=your_secure_api_token_here

# 🌟 외부 알림(Webhook) 대상 설정 | 🌟 Outbound webhook targets
# Discord incoming webhook URL
#WEBHOOK_DISCORD_URL=https://discord.com/api/webhooks/...
# Slack incoming webhook URL
#WEBHOOK_SLACK_URL=https://hooks.slack.com/services/...
# Telegram option A: full URL (can include chat_id query)
#WEBHOOK_TELEGRAM_URL=https://api.telegram.org/bot<token>/sendMessage
# Telegram option B: token + chat_id
#WEBHOOK_TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#WEBHOOK_TELEGRAM_CHAT_ID=123456789
# Additional generic targets (name=url, comma-separated)
#WEBHOOK_NOTIFY_URLS=ops=https://example.com/hook,backup=https://example.net/hook
# Request timeout (seconds)
#WEBHOOK_NOTIFY_TIMEOUT=5
