# Python Cache
__pycache__/
*.pyc

# Local Environment & Secrets
.env
.venv/
venv/
ENV/
deploy.py
test/

# Project Specific Data (DB & Cache)
db/*.db
db/*.db-wal
db/*.db-shm
db/*.db-journal
cache/*
!cache/.gitkeep
covers/*
!covers/.gitkeep

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Exclude sensitive scratch and DB backups
scratch/
db/*.db.bak

# Exclude local test database and sample assets
test/

# User local docker-compose override
docker-compose.override.yml

# Logs
logs/*
!logs/.gitkeep

